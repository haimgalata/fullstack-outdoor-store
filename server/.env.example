# Copy this file to .env in the same folder (server/) and fill in real values.
# The server loads .env from its working directory (always run from server/ or use npm --prefix server).

# -----------------------------------------------------------------------------
# MongoDB (required)
# -----------------------------------------------------------------------------
# Atlas: Database → Connect → Drivers → copy the SRV connection string.
# Replace <password> with your DB user password and set a database name before query params, e.g.
# mongodb+srv://user:pass@cluster.xxxxx.mongodb.net/outdoor_shop?retryWrites=true&w=majority
#
# Network Access: allow your IP for local dev, or 0.0.0.0/0 when deploying (e.g. Railway).
# This app accepts either variable name:
MONGO_URI=mongodb+srv://username:password@cluster.example.mongodb.net/outdoor_shop?retryWrites=true&w=majority
# MONGODB_URI=mongodb+srv://username:password@cluster.example.mongodb.net/outdoor_shop?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Server port (optional)
# -----------------------------------------------------------------------------
# Local default is 5000. Railway and most hosts set PORT automatically — omit locally or override as needed.
# PORT=5000

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
# This project does not use JWT, OAuth, or paid third-party APIs — no extra API keys are required.
